rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public site: read-only collections
    match /events/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /news/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /projects/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /partners/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /site-config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // All other collections (users, etc.) are blocked entirely
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
